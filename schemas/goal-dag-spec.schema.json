{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-dag/schemas/goal-dag-spec.schema.json",
  "title": "GoalDagSpec Producer Input",
  "description": "Producer-side GoalDagSpec accepted by goal-dag before round-tripping through the goal-runner/agent-goal-runtime parser. Spec-only fields are stripped from runtime DAG JSON and preserved in the planning trace sidecar.",
  "type": "object",
  "additionalProperties": false,
  "required": ["objective", "nodes"],
  "properties": {
    "version": { "const": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "defaults": { "$ref": "#/$defs/defaults" },
    "modelRouting": { "$ref": "#/$defs/modelRouting" },
    "openQuestions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "nodeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risk": { "enum": ["low", "medium", "high"] },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "validators": { "$ref": "#/$defs/nonEmptyStringArray" },
        "workspaceStrategy": { "type": "string", "minLength": 1 },
        "completionGates": { "$ref": "#/$defs/nonEmptyStringArray" },
        "conflicts": { "$ref": "#/$defs/conflicts" },
        "modelScenario": { "type": "string", "minLength": 1 },
        "risk": { "$ref": "#/$defs/risk" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "objective"],
      "properties": {
        "id": { "$ref": "#/$defs/nodeId" },
        "objective": { "type": "string", "minLength": 1 },
        "after": {
          "type": "array",
          "items": { "$ref": "#/$defs/nodeId" }
        },
        "outputs": { "$ref": "#/$defs/nonEmptyStringArray" },
        "validators": { "$ref": "#/$defs/nonEmptyStringArray" },
        "conflicts": { "$ref": "#/$defs/conflicts" },
        "scope": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "validation": { "$ref": "#/$defs/validation" },
        "workspaceStrategy": { "type": "string", "minLength": 1 },
        "workspace": { "$ref": "#/$defs/workspace" },
        "risk": { "$ref": "#/$defs/risk" },
        "completionGates": { "$ref": "#/$defs/nonEmptyStringArray" },
        "modelScenario": { "type": "string", "minLength": 1 },
        "thinkingLevel": { "type": "string", "minLength": 1 },
        "consumes": { "$ref": "#/$defs/nonEmptyStringArray" },
        "produces": { "$ref": "#/$defs/nonEmptyStringArray" },
        "evidence": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/evidenceReference" }
            ]
          }
        },
        "modelRationale": { "type": "string", "minLength": 1 },
        "acceptanceCriteria": { "$ref": "#/$defs/nonEmptyStringArray" },
        "decompositionRationale": { "type": "string", "minLength": 1 }
      }
    },
    "conflicts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": { "$ref": "#/$defs/nonEmptyStringArray" },
        "modules": { "$ref": "#/$defs/nonEmptyStringArray" },
        "capabilities": { "$ref": "#/$defs/nonEmptyStringArray" }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["worktreeSlug"] },
        { "required": ["branch"] },
        { "required": ["baseRef"] }
      ],
      "properties": {
        "worktreeSlug": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "baseRef": { "type": "string", "minLength": 1 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "testSpecNodeId": { "$ref": "#/$defs/nodeId" },
        "approvedByNodeId": { "$ref": "#/$defs/nodeId" },
        "artifactLocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactLock" }
        },
        "requiredEvidence": { "$ref": "#/$defs/nonEmptyStringArray" },
        "onAuditTestGap": { "type": "string", "minLength": 1 },
        "diffBaseRef": { "type": "string", "minLength": 1 },
        "auditReportPaths": { "$ref": "#/$defs/nonEmptyStringArray" }
      }
    },
    "artifactLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "sourceNodeId": { "$ref": "#/$defs/nodeId" },
        "approvedByNodeId": { "$ref": "#/$defs/nodeId" },
        "approvedAt": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "quote": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 },
        "supports": { "$ref": "#/$defs/nonEmptyStringArray" }
      }
    },
    "modelRouting": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "scenarios": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["model"],
            "additionalProperties": true,
            "properties": {
              "model": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:[-_.][a-z][a-z0-9]*)*/[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*$"
              },
              "description": { "type": "string" }
            }
          }
        },
        "controllerScenario": { "type": "string", "minLength": 1 },
        "defaultSubagentScenario": { "type": "string", "minLength": 1 },
        "rules": { "type": "array" }
      }
    }
  }
}
