{
  "name": "goal-dag",
  "version": "0.1.0",
  "type": "module",
  "description": "Stage 2 producer for Goal DAG files consumed by the goal-runner stage.",
  "keywords": [
    "pi-package",
    "goal-dag",
    "goal-runner"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./skills": "./skills"
  },
  "bin": {
    "goal-dag": "./dist/scripts/build-dag.js"
  },
  "files": [
    "dist",
    "skills",
    "schemas",
    "catalogs",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/tests/*.test.js",
    "check": "npm run build && npm test",
    "prepack": "npm run build"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5345534/goal-dag.git"
  },
  "bugs": {
    "url": "https://github.com/a5345534/goal-dag/issues"
  },
  "homepage": "https://github.com/a5345534/goal-dag#readme",
  "dependencies": {
    "goal-contract": "github:a5345534/goal-contract#dc48e42f98e8c585fad8f5f2c94ab42c9cdcca86"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
